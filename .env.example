# =============================================================================
# ADDMARKET — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs réelles
# NE JAMAIS COMMITTER .env.local — il est dans .gitignore
# =============================================================================

# --- Next.js ---
NODE_ENV=development

# --- Supabase (projet DEV) ---
# Récupérables dans : supabase.com → ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CRITIQUE : service_role bypass toutes les RLS
# Uniquement dans Server Actions ou API Routes — JAMAIS dans le bundle client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Base de données (Drizzle ORM) ---
# Supabase → Settings → Database → Connection string → mode "Session"
# Utiliser le pooler session (port 5432), PAS transaction (port 6543) avec Drizzle
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Cloudinary (Phase 2 — images publiques) ---
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Upstash Redis (Phase 1 — rate limiting) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Resend (emails transactionnels) ---
# RESEND_API_KEY=

# --- Sentry (monitoring erreurs) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# --- PostHog (analytics, hébergé EU) ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
